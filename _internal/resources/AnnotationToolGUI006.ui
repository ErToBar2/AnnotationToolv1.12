    <string notr="true">/* Styles for QPushButton when checked (active state) */
QPushButton:checked {
    /* Remove background-color to preserve label-specific color */
    border: 3px solid #4FB9E9; /* Add a distinct border to indicate active state */
}



/* General QPushButton styling */
QPushButton {
    /* Optional: Set default padding */
    padding: 5px;
    /* Optional: Set default border */
